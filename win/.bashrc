alias ls='ls --color=auto'
alias l='ls -l --color=auto'
alias la='ls -la --color=auto'

alias ..='cd ..'

alias gco='git checkout'
alias gcb='gco -b'

alias gp='git push'
alias gpf='gp --force'

alias gc='git commit -v'
alias gca='gc --amend'

alias gst='git status'
alias glg='git log'
alias ga='git add'
alias gd='git diff'
