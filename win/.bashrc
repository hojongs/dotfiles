alias ls='ls --color=auto'
alias l='ls -l --color=auto'
alias la='ls -la --color=auto'

alias ..='cd ..'

alias gst='git status'

alias gco='git checkout'
alias gcb='gco -b'

alias gp='git push'
alias gpf='gp --force'

alias gc='git commit -v'
alias gca='gc --amend'

alias glg='git log'

alias ga='git add'

